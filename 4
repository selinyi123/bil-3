        record["exception"] = str(kwargs["exception"])
    print(json.dumps(record, ensure_ascii=False))
    try:
        from app.db import redis
        # fire-and-forget 发布到 Redis，但不阻塞调用者
        asyncio.ensure_future(safe_publish(redis, "structured_logs", json.dumps(record, ensure_ascii=False)))
    except Exception:
        pass

async def safe_publish(redis_client, channel, message):
    try:
        await redis_client.publish(channel, message)
    except Exception:
