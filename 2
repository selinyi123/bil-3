  const [showForm, setShowForm] = useState(false);
  const [cookieText, setCookieText] = useState('');
  const [loginMode, setLoginMode] = useState('cookie'); // 'cookie' | 'qrcode'
  const load = () => fetchJSON('/accounts/').then(setAccounts);
  useEffect(() => { load(); }, []);

