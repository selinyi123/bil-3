    if (!cookieText.trim()) {
      alert('请粘贴 Cookie 内容');
      return;
    }
    // 简易模式：自动设置默认参数，把 cookie 作为加密凭证存储
    await postJSON('/accounts/', {
      platform: 'bilibili',
      fingerprint_id: 1, // 使用默认指纹
      proxy_id: null,
      encrypted_credential: cookieText.trim()
    });
    setCookieText('');
    setShowForm(false);
    load();
    alert('账号添加成功！');
  };

  return (
    <div className="card">
      <div className="flex justify-between items-center mb-4">
        <h3 className="text-lg font-semibold">账号管理</h3>
        <button onClick={() => setShowForm(!showForm)} className="px-3 py-1.5 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm font-medium transition">
          {showForm ? '取消' : '+ 添加账号'}
        </button>
      </div>

      {showForm && (
        <div className="mb-4 p-3 bg-slate-700/50 rounded-lg border border-slate-600 space-y-3">
          {/* 登录方式切换 */}
          <div className="flex gap-2">
            <button onClick={() => setLoginMode('cookie')} className={`px-3 py-1 rounded text-sm ${loginMode === 'cookie' ? 'bg-blue-600 text-white' : 'bg-slate-600 text-slate-300'}`}>Cookie 登录</button>
            <button onClick={() => setLoginMode('qrcode')} className={`px-3 py-1 rounded text-sm ${loginMode === 'qrcode' ? 'bg-blue-600 text-white' : 'bg-slate-600 text-slate-300'}`}>二维码登录</button>
          </div>

          {loginMode === 'cookie' && (
            <div className="space-y-2">
              <div className="text-xs text-slate-400 bg-slate-800 p-2 rounded">
                <p className="font-medium text-yellow-400 mb-1">📋 Cookie 获取方法：</p>
