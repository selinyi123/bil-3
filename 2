六、关键运维命令速查

```bash
# 进入项目目录
cd /root/eve-one

# 查看容器状态
docker compose ps

# 查看实时日志
docker compose logs -f worker
docker compose logs -f core-api

# 重启服务
docker compose restart core-api

# 重建容器（环境变量变更后必须重建）
docker compose up -d core-api

# 数据库操作（必须用 source .env 加载密码）
set -a && source .env && set +a
docker compose exec -T mysql mysql -uuser -p"$MYSQL_PASSWORD" lottery -e "SELECT * FROM accounts;"

# 前端重新构建
cd /root/eve-one/frontend && npm run build

# 测试 Server 酱
curl -X POST http://localhost:8080/api/notify/send \
  -H "Content-Type: application/json" \
  -d '{"title":"测试","content":"通知通道正常","channel":"serverchan"}'
```
