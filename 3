# worker/app/main.py 中增加

import signal, importlib, sys

from redis import Redis



redis = Redis.from_url(os.getenv("REDIS_URL"))

pubsub = redis.pubsub()

pubsub.subscribe("system:reload")



def graceful_reload(signum, frame):

    """收到信号后，完成当前任务再退出进程，由Docker/Supervisor自动拉起新代码"""

    print("[RELOAD] Signal received, finishing current job...")

    # 标记不再接收新任务

    global ACCEPTING_TASKS

    ACCEPTING_TASKS = False



signal.signal(signal.SIGHUP, graceful_reload)



# 独立线程监听Redis重载指令

def reload_listener():

    for message in pubsub.listen():

        if message["type"] == "message":

            print(f"[RELOAD] Redis command: {message['data']}")

            os.kill(os.getpid(), signal.SIGHUP)



threading.Thread(target=reload_listener, daemon=True).start()

