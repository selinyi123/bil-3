三、双通道消息通知系统（Server酱 + 飞书）


3.1 通知分类与通道策略


通知类型	优先级	通道	说明	


登录二维码	🔴紧急	Server酱 + 飞书	带二维码图片，需立即扫码	


中奖通知	🟠重要	Server酱 + 飞书	附带奖品信息、截图链接	


风控/封号告警	🔴紧急	Server酱 + 飞书	@全员，立即处理	


系统故障	🔴紧急	Server酱 + 飞书	Worker崩溃、数据库断开	


任务完成日报	🟡普通	飞书	每日汇总，低打扰	


更新成功/回滚	🟢信息	飞书	仅管理员频道	


3.2 通知服务核心代码



# core/app/services/notifier.py

import os, requests, base64

from typing import Optional

from enum import Enum



class NotifyLevel(Enum):

    CRITICAL = "critical"   # 立即推送所有通道

    HIGH = "high"           # Server酱 + 飞书

    NORMAL = "normal"       # 仅飞书

    LOW = "low"             # 仅日志记录



class Notifier:

    def __init__(self):

        self.serverchan_key = os.getenv("SERVERCHAN_KEY")

        self.feishu_webhook = os.getenv("FEISHU_WEBHOOK")

    

    def _serverchan(self, title: str, desp: str, image_b64: Optional[str] = None):

        """Server酱推送（支持Markdown）"""

        if not self.serverchan_key:

            return

        url = f"https://sctapi.ftqq.com/{self.serverchan_key}.send"

        payload = {

            "title": title,

            "desp": desp,

            "channel": "9"  # 企业微信通道优先

        }

        if image_b64:

            # Server酱支持base64图片前缀

            payload["desp"] += f"\n\n![qr](data:image/png;base64,{image_b64})"

        try:

            requests.post(url, data=payload, timeout=10)

        except Exception as e:

            print(f"[ServerChan Failed] {e}")

    

    def _feishu(self, title: str, content: str, image_b64: Optional[str] = None):

        """飞书Webhook富文本推送"""

        if not self.feishu_webhook:

            return

        elements = [{"tag": "div", "text": {"tag": "lark_md", "content": content}}]

        if image_b64:

            elements.append({

                "tag": "img",

                "img_key": image_b64,  # 实际需先上传图片到飞书获取img_key，简化版用markdown

                "alt": {"tag": "plain_text", "content": "image"}

            })

        

        payload = {

            "msg_type": "interactive",

            "card": {

                "header": {"title": {"tag": "plain_text", "content": title}, "template": "red"},

                "elements": elements

            }

        }

        try:

            requests.post(self.feishu_webhook, json=payload, timeout=10)

        except Exception as e:

            print(f"[Feishu Failed] {e}")

    

    def send(self, level: NotifyLevel, title: str, content: str, image_path: Optional[str] = None):

        """统一发送入口"""

        image_b64 = None

        if image_path and os.path.exists(image_path):

            with open(image_path, "rb") as f:

                image_b64 = base64.b64encode(f.read()).decode()

        

        if level in (NotifyLevel.CRITICAL, NotifyLevel.HIGH):

            self._serverchan(title, content, image_b64)

            self._feishu(title, content, image_b64)

        elif level == NotifyLevel.NORMAL:

            self._feishu(title, content, image_b64)

        

        # 所有级别都写库留痕

        self._persist_log(level.value, title, content)

    

    def _persist_log(self, level, title, content):

        from sqlalchemy import text

        # 异步写入通知日志表

        pass



