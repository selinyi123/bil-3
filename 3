四、数据库设计（完整版）



-- init.sql

CREATE DATABASE IF NOT EXISTS lottery CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;

USE lottery;



-- 1. 账号主表

CREATE TABLE accounts (

    id BIGINT PRIMARY KEY AUTO_INCREMENT,

    platform VARCHAR(32) NOT NULL COMMENT 'bilibili/xiaohongshu/weibo/douyin',

    username VARCHAR(128) NOT NULL,

    display_name VARCHAR(128),

    credential_json TEXT COMMENT '加密后的Cookie/Token',

    fingerprint_id BIGINT NOT NULL,

    proxy_url VARCHAR(256),

    status ENUM('active','nurturing','frozen','dead') DEFAULT 'nurturing',

    level ENUM('new','growing','stable','vip') DEFAULT 'new',

    risk_score INT DEFAULT 0 COMMENT '0-100, 越高越危险',

    daily_quota_used INT DEFAULT 0,

    daily_quota_max INT DEFAULT 10,

    last_login DATETIME,

    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,

    UNIQUE KEY uk_platform_user (platform, username)

) ENGINE=InnoDB;



-- 2. 设备指纹库

CREATE TABLE fingerprints (

    id BIGINT PRIMARY KEY AUTO_INCREMENT,

    name VARCHAR(64),

    user_agent VARCHAR(512),

    viewport_width INT,

    viewport_height INT,

    device_scale_factor DECIMAL(3,2),

    platform VARCHAR(32),

    canvas_noise VARCHAR(64),

    webgl_vendor VARCHAR(128),

    webgl_renderer VARCHAR(128),

    fonts_hash VARCHAR(64),

    timezone VARCHAR(32),

    language VARCHAR(32),

    cpu_cores INT,

    memory INT COMMENT 'GB',

    touch_support BOOLEAN DEFAULT FALSE,

    created_at DATETIME DEFAULT CURRENT_TIMESTAMP

) ENGINE=InnoDB;



-- 3. 抽奖活动表

CREATE TABLE lotteries (

    id BIGINT PRIMARY KEY AUTO_INCREMENT,

    platform VARCHAR(32) NOT NULL,

    source_url VARCHAR(512) NOT NULL,

    author_id VARCHAR(128),

    title VARCHAR(512),

    description TEXT,

    requirements JSON COMMENT '["follow","like","comment","repost"]',

    prize_desc VARCHAR(256),

    prize_value DECIMAL(10,2) DEFAULT 0 COMMENT '预估价值',

    end_time DATETIME,

    status ENUM('pending','joined','won','lost','expired') DEFAULT 'pending',

    discovered_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    joined_at DATETIME,

    INDEX idx_end_time (end_time),

    INDEX idx_status (status)

) ENGINE=InnoDB;



-- 4. 参与记录表

CREATE TABLE join_logs (

    id BIGINT PRIMARY KEY AUTO_INCREMENT,

    account_id BIGINT NOT NULL,

    lottery_id BIGINT NOT NULL,

    actions_taken JSON COMMENT '实际执行的动作',

    result ENUM('success','failed','skipped') DEFAULT 'success',

    fail_reason VARCHAR(256),

    screenshot_path VARCHAR(512),

    ip_used VARCHAR(64),

    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (account_id) REFERENCES accounts(id),

    FOREIGN KEY (lottery_id) REFERENCES lotteries(id)

) ENGINE=InnoDB;



-- 5. 养号任务表

CREATE TABLE nurture_tasks (

    id BIGINT PRIMARY KEY AUTO_INCREMENT,

    account_id BIGINT NOT NULL,

    task_type ENUM('browse','like','comment','follow','search','idle') NOT NULL,

    target_url VARCHAR(512),

    scheduled_at DATETIME NOT NULL,

    executed_at DATETIME,

    duration_sec INT COMMENT '实际停留秒数',

    metadata JSON COMMENT '浏览内容标签、互动对象等',

    status ENUM('pending','running','done','failed') DEFAULT 'pending',

    FOREIGN KEY (account_id) REFERENCES accounts(id),

    INDEX idx_scheduled (scheduled_at, status)

) ENGINE=InnoDB;



-- 6. 风控事件表

CREATE TABLE risk_events (

    id BIGINT PRIMARY KEY AUTO_INCREMENT,

    account_id BIGINT NOT NULL,

    platform VARCHAR(32),

    event_type ENUM('captcha','rate_limit','login_expired','behavior_check','ban') NOT NULL,

    trigger_reason VARCHAR(256),

    page_screenshot VARCHAR(512),

    triggered_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    auto_action ENUM('cooldown','pause','notify','none') DEFAULT 'notify',

    resolved_at DATETIME,

    FOREIGN KEY (account_id) REFERENCES accounts(id)

) ENGINE=InnoDB;



-- 7. 通知日志表

CREATE TABLE notify_logs (

    id BIGINT PRIMARY KEY AUTO_INCREMENT,

    level VARCHAR(16),

    channel VARCHAR(32) COMMENT 'serverchan/feishu',

    title VARCHAR(256),

    content TEXT,

    sent_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    status ENUM('sent','failed') DEFAULT 'sent'

) ENGINE=InnoDB;



-- 8. 系统版本表（配合热更新）

CREATE TABLE system_versions (

    id BIGINT PRIMARY KEY AUTO_INCREMENT,

    version_tag VARCHAR(32) NOT NULL,

    backup_path VARCHAR(512),

    deployed_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    rolled_back_at DATETIME,

    status ENUM('active','rolled_back') DEFAULT 'active'

) ENGINE=InnoDB;


