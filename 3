二、在线热更新系统（零停机部署）


2.1 设计原则



不重启服务器：整个Ubuntu服务器保持运行


不重建容器：Docker容器不重启，仅重载业务代码


可回滚：更新失败自动回退上一版本


手机端可操作：通过Web后台上传zip包完成更新



2.2 热更新流程



[手机/PC浏览器] → [上传 update.zip] → [Nginx转发] → [Core-API接收]

                                                              ↓

[校验签名/大小] → [备份当前版本到 /backups/app-{timestamp}.tar.gz]

                                                              ↓

[解压到 /app/releases/new/] → [文件一致性校验] → [rsync替换 /app/app/]

                                                              ↓

[触发 Worker HUP 信号重载] → [健康检查通过] → [通知：更新成功]

                                                              ↓

[健康检查失败] → [自动回滚] → [通知：更新失败已回滚]

2.3 后端热更新模块（FastAPI）



# core/app/api/update.py

import os, shutil, hashlib, tarfile, subprocess

from fastapi import APIRouter, UploadFile, File, HTTPException, Depends

from datetime import datetime



router = APIRouter(prefix="/system", tags=["System Update"])



UPDATE_TOKEN = os.getenv("UPDATE_TOKEN")

RELEASES_DIR = "/app/releases"

BACKUP_DIR = "/app/backups"

APP_DIR = "/app/app"

MAX_SIZE = 50 * 1024 * 1024  # 50MB



def verify_token(token: str):

    if token != UPDATE_TOKEN:

        raise HTTPException(403, "Invalid update token")



@router.post("/upload-update")

async def upload_update(

    file: UploadFile = File(...),

    token: str = Depends(verify_token)

):

    # 1. 校验

    if not file.filename.endswith(".zip"):

        raise HTTPException(400, "Only .zip allowed")

    

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")

    zip_path = f"{RELEASES_DIR}/update_{timestamp}.zip"

    

    with open(zip_path, "wb") as f:

        content = await file.read()

        if len(content) > MAX_SIZE:

            raise HTTPException(400, "File too large")

        f.write(content)

    

    # 2. 备份当前版本

    backup_path = f"{BACKUP_DIR}/app_{timestamp}.tar.gz"

    with tarfile.open(backup_path, "w:gz") as tar:

        tar.add(APP_DIR, arcname="app")

    

    # 3. 解压到新目录

    extract_dir = f"{RELEASES_DIR}/new_{timestamp}"

    os.makedirs(extract_dir, exist_ok=True)

    shutil.unpack_archive(zip_path, extract_dir, "zip")

    

    # 4. 校验关键文件存在

    required = ["main.py", "config.yaml", "adapters/"]

    for item in required:

        if not os.path.exists(os.path.join(extract_dir, item)):

            shutil.rmtree(extract_dir)

            raise HTTPException(400, f"Missing {item} in package")

    

    # 5. 原子替换（先同步到临时目录，再mv）

    temp_app = f"{APP_DIR}_new"

    shutil.copytree(extract_dir, temp_app, dirs_exist_ok=True)

    

    # 6. 执行替换脚本（避免Python文件被占用问题）

    swap_script = f"""

    mv {APP_DIR} {APP_DIR}_old

    mv {temp_app} {APP_DIR}

    rm -rf {APP_DIR}_old

    """

    subprocess.run(["bash", "-c", swap_script], check=True)

    

    # 7. 通知Worker热重载（通过Redis发布信号）

    from redis import Redis

    redis = Redis.from_url(os.getenv("REDIS_URL"))

    redis.publish("system:reload", f"reload:{timestamp}")

    

    return {"status": "success", "version": timestamp, "backup": backup_path}



@router.post("/rollback")

async def rollback(token: str = Depends(verify_token)):

    """紧急回滚到最近备份"""

    backups = sorted(os.listdir(BACKUP_DIR), reverse=True)

    if not backups:

        raise HTTPException(404, "No backup found")

    

    latest = os.path.join(BACKUP_DIR, backups[0])

    # 解压备份覆盖当前

    shutil.unpack_archive(latest, "/app/", "tar:gz")

    

    return {"status": "rollback_success", "to": backups[0]}

