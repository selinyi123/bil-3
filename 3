# 伪代码：账号登录流程

async def login_account(account_id: int, method: str = "qr"):

    account = db.get(account_id)

    adapter = get_adapter(account.platform)

    

    if method == "qr":

        # 生成二维码

        qr_path = await adapter.generate_qr()

        # 立即推送到手机

        notify_qr_login(account.platform, account.username, qr_path)

        # 轮询等待扫码（2分钟超时）

        success = await adapter.wait_for_scan(timeout=120)

        if not success:

            notify_system_fault("Login", f"{account.username} 扫码超时")

            return False

    

    elif method == "cookie":

        decrypted_cookies = aes_decrypt(account.credential_json)

        await adapter.load_cookies(decrypted_cookies)

    

    # 登录成功后保存新Cookie

    new_cookies = await adapter.export_cookies()

    account.credential_json = aes_encrypt(new_cookies)

    account.last_login = now()

    db.commit()

    return True

6.2 抽奖参与闭环



async def participate_lottery(account_id: int, lottery_id: int):

    account = db.get(account_id)

    lottery = db.get(lottery_id)

    adapter = get_adapter(account.platform, account.fingerprint_id)

    

    # 风控前置检查

    if account.risk_score > 70 or account.daily_quota_used >= account.daily_quota_max:

        return {"status": "skipped", "reason": "risk_or_quota"}

    

    # 养号前置：抽奖前必须完成今日养号

    if not await check_nurture_done(account_id):

        await run_nurture_task(account_id, duration=10)  # 紧急补养号

    

    try:

        # 执行抽奖动作链

        result = await adapter.join_lottery(lottery)

        

        # 记录日志

        log = JoinLog(..., screenshot=result.screenshot)

        db.add(log)

        account.daily_quota_used += 1

        

        # 如果中奖

        if result.is_winner:

            notify_lottery_win(account.platform, account.username, 

                             lottery.prize_desc, result.screenshot)

        

        return {"status": "success"}

        

    except RiskException as e:

        # 风控熔断

        await handle_risk_event(account, e)

        return {"status": "failed", "reason": "risk"}

